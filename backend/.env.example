# ============================================================
# MAO 平台后端配置示例 - 复制为 .env 并填写实际值
# ============================================================

# 应用
APP_ENV=development
APP_SECRET_KEY=change-me-in-production-use-32-chars-min
APP_DEBUG=true
APP_LOG_LEVEL=INFO

# 数据库 (MySQL 8.0+)
DATABASE_URL=mysql+aiomysql://mao_user:mao_pass@localhost:3306/mao_db
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_STATE_DB=1
REDIS_TASK_SNAPSHOT_TTL=86400

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_GROUP_ID=mao-backend
KAFKA_TOPIC_AUDIT_THOUGHT=mao.audit.thought
KAFKA_TOPIC_AUDIT_ACTION=mao.audit.action
KAFKA_TOPIC_AUDIT_CARD_EMIT=mao.audit.card_emit
KAFKA_TOPIC_AUDIT_CALLBACK=mao.audit.callback

# 大模型
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_DEFAULT_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# 飞书
FEISHU_APP_ID=cli_...
FEISHU_APP_SECRET=...
FEISHU_VERIFICATION_TOKEN=...
FEISHU_ENCRYPT_KEY=...

# JWT
JWT_SECRET_KEY=change-me-jwt-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=480

# 执行引擎
ENGINE_MAX_STEPS=7
ENGINE_STEP_TIMEOUT_SECONDS=30
ENGINE_MAX_RETRIES=3
ENGINE_CIRCUIT_BREAKER_THRESHOLD=3
